{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 26,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs-debug",
      "displayName": "Visual Studio 2026 Debug",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "vs-release",
      "displayName": "Visual Studio 2026 Release",
      "inherits": "vs-debug",
      "binaryDir": "${sourceDir}/build-release"
    }
  ],
  "buildPresets": [
    {
      "name": "vs-debug",
      "configurePreset": "vs-debug",
      "configuration": "Debug"
    },
    {
      "name": "vs-release",
      "configurePreset": "vs-release",
      "configuration": "Release"
    }
  ],
  "packagePresets": [
    {
      "name": "vs-release-portable",
      "configurePreset": "vs-release",
      "configurations": [
        "Release"
      ],
      "generators": [
        "ZIP"
      ]
    }
  ]
}
